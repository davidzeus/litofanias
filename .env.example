# Copiá este archivo como .env y completá con tus valores.

# --- Ollama (mejora de imagen con IA) ---
OLLAMA_HOST=http://tu-servidor-ollama:11434
OLLAMA_MODEL=ministral-es:latest
OLLAMA_TIMEOUT_SEGUNDOS=25

# --- Ventana horaria en que la mejora con IA está habilitada ---
IA_HORA_INICIO=15
IA_HORA_FIN=5
IA_ZONA_HORARIA=America/Argentina/Buenos_Aires

# --- Límites de uso (servicio público y gratuito) ---
RATE_LIMIT=10/minute
RATE_LIMIT_IA=5/minute
